{
  "name": "@mecatronics/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "seed:admin": "tsx src/scripts/seed-admin.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@prisma/client": "^6.16.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.0",
    "pdfkit": "^0.17.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@types/pdfkit": "^0.17.6",
    "prisma": "^6.16.0",
    "tsx": "^4.20.5",
    "typescript": "~6.0.2",
    "vitest": "^3.2.4"
  }
}
